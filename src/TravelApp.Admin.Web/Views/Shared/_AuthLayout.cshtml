<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelApp Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .auth-body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            background: radial-gradient(circle at top left, rgba(255, 122, 69, 0.18), transparent 28%), radial-gradient(circle at top right, rgba(163, 92, 255, 0.16), transparent 26%), linear-gradient(180deg, #0e111a 0%, #0b0d14 100%);
        }

        .auth-shell {
            width: min(100%, 460px);
            position: relative;
        }

        .auth-shell::before {
            content: "";
            position: absolute;
            inset: -24px;
            border-radius: 32px;
            background: linear-gradient(135deg, rgba(255, 122, 69, 0.12), rgba(163, 92, 255, 0.08));
            filter: blur(18px);
            z-index: 0;
        }

        .auth-card {
            position: relative;
            z-index: 1;
            padding: 32px;
            border-radius: 28px;
            background: linear-gradient(180deg, rgba(20, 25, 36, 0.96), rgba(13, 17, 25, 0.98));
            box-shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
            color: #f2f5fb;
        }

        .auth-logo {
            width: 72px;
            height: 72px;
            border-radius: 22px;
            display: grid;
            place-items: center;
            margin: 0 auto;
            font-size: 2rem;
            background: linear-gradient(135deg, rgba(255, 122, 69, 0.28), rgba(163, 92, 255, 0.18));
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
        }

        .auth-card .text-muted { color: #8d95a8 !important; }
        .auth-card .form-label { font-weight: 600; margin-bottom: 8px; }
        .auth-input {
            background-color: rgba(255, 255, 255, 0.03) !important;
            border-color: rgba(255, 255, 255, 0.08) !important;
            color: #f2f5fb !important;
            border-radius: 14px;
            padding-top: 14px;
            padding-bottom: 14px;
            box-shadow: none !important;
        }
        .auth-input::placeholder { color: #92a0bb; }
        .auth-input:focus { border-color: rgba(255, 122, 69, 0.72) !important; box-shadow: 0 0 0 .2rem rgba(255, 122, 69, 0.16) !important; }
        .auth-button {
            border: 0;
            border-radius: 14px;
            padding: 14px 16px;
            background: linear-gradient(135deg, #ff7a45 0%, #d31963 100%);
            box-shadow: 0 12px 28px rgba(211, 25, 99, 0.25);
            font-weight: 700;
        }
        .auth-button:hover, .auth-button:focus { background: linear-gradient(135deg, #ff8a5d 0%, #df2b72 100%); }
        .auth-card .text-danger { color: #ff8cab !important; }
        .auth-card .validation-summary-errors {
            background: rgba(255, 76, 126, 0.08);
            border: 1px solid rgba(255, 76, 126, 0.24);
            border-radius: 14px;
            padding: 12px 14px;
        }
    </style>
</head>
<body class="auth-body">
    <main role="main">
        @RenderBody()
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@using TravelApp.Application.Dtos.Users
@model IReadOnlyList<UserAdminDto>

@{
    ViewData["Title"] = "Quản lý User";
}

@{
    var featuredUser = Model.FirstOrDefault();
}

<div class="dashboard-grid">
    <div class="section-header">
        <div>
            <h1 class="section-title">Quản lý User</h1>
            <p class="section-subtitle">Tạo, sửa, xóa và quản lý trạng thái tài khoản.</p>
        </div>
        <div class="section-actions">
            <span class="soft-badge">@Model.Count user</span>
            <div class="user-search">
                <input type="search" class="form-control" placeholder="Tìm user..." data-user-search />
            </div>
            <a class="btn btn-primary" asp-action="Create">+ Tạo user mới</a>
        </div>
    </div>

    <div class="poi-grid" data-user-index>
        <div class="d-grid gap-3">
            @foreach (var item in Model)
            {
                <div class="card admin-card h-100" data-user-row
                     data-search-text="@($"{item.UserName} {item.Email} {string.Join(" ", item.Roles.Select(x => x.Name))} {(item.IsActive ? "active" : "inactive")}")"
                     data-user-name="@item.UserName"
                     data-user-email="@item.Email"
                     data-user-status="@(item.IsActive ? "Active" : "Inactive")"
                     data-user-created="@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")"
                     data-user-roles="@string.Join("|", item.Roles.Select(x => x.Name))">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="soft-badge mb-2">User</div>
                                <h5 class="card-title mb-1">@item.UserName</h5>
                                <div class="text-muted small">@item.Email</div>
                            </div>
                            <span class="soft-badge">@(item.IsActive ? "Active" : "Inactive")</span>
                        </div>

                        <div class="mt-3 mb-3 small text-muted">
                            Created: @item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")
                        </div>

                        <div class="preview-list mb-3">
                            <li><span>Roles</span><strong>@(item.Roles.Count == 0 ? "—" : string.Join(", ", item.Roles.Select(x => x.Name)))</strong></li>
                        </div>

                        <div class="user-card-actions">
                            <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this user?');">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="preview-card user-feature-card" data-user-feature-card>
            <div class="preview-hero">
                <div class="user-preview-shell">
                    <div class="user-avatar" data-user-preview="avatar">@((featuredUser?.UserName ?? "U").Substring(0, 1).ToUpperInvariant())</div>
                    <div>
                        <div class="preview-title" data-user-preview="name">@(featuredUser?.UserName ?? "No users")</div>
                        <div class="preview-subtitle" data-user-preview="email">@(featuredUser?.Email ?? "Tạo user đầu tiên để xem preview")</div>
                    </div>
                </div>
                <div class="preview-overlay"></div>
                <div class="preview-meta">
                    <div>
                        <div class="preview-title">User Preview</div>
                        <div class="preview-subtitle" data-user-preview="status">@(featuredUser?.Email ?? "Chưa có dữ liệu")</div>
                    </div>
                    <span class="soft-badge" data-user-preview="badge">Index</span>
                </div>
            </div>
            <div class="preview-body">
                <div class="preview-stats">
                    <div class="preview-stat">
                        <div class="label">Total users</div>
                        <div class="value">@Model.Count</div>
                    </div>
                    <div class="preview-stat">
                        <div class="label">Active</div>
                        <div class="value">@Model.Count(x => x.IsActive)</div>
                    </div>
                    <div class="preview-stat">
                        <div class="label">Inactive</div>
                        <div class="value">@Model.Count(x => !x.IsActive)</div>
                    </div>
                </div>

                <ul class="preview-list mt-3">
                    <li><span>Username</span><strong data-user-preview="name-text">@(featuredUser?.UserName ?? "—")</strong></li>
                    <li><span>Email</span><strong data-user-preview="email-text">@(featuredUser?.Email ?? "—")</strong></li>
                    <li><span>Status</span><strong data-user-preview="status-text">@(featuredUser is null ? "—" : (featuredUser.IsActive ? "Active" : "Inactive"))</strong></li>
                    <li>
                        <span>Roles</span>
                        <div class="user-role-badges" data-user-preview="roles">
                            @(featuredUser is null || featuredUser.Roles.Count == 0 ? "—" : string.Join(", ", featuredUser.Roles.Select(x => x.Name)))
                        </div>
                    </li>
                </ul>
                <div class="user-no-results mt-3" data-user-no-results hidden>Không có user nào khớp bộ lọc.</div>
            </div>
        </div>
    </div>
</div>

@model TravelApp.Admin.Web.Models.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-shell">
    <div class="auth-card shadow-lg">
        <div class="text-center mb-4">
            <div class="auth-logo mb-3">🍜</div>
            <h1 class="h3 fw-bold mb-1">TravelApp Admin</h1>
            <p class="text-muted mb-0">CMS Phố Ẩm Thực Việt</p>
        </div>

        <form asp-action="Login" method="post" class="vstack gap-3">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div>
                <label asp-for="UserName" class="form-label">Tài khoản</label>
                <input asp-for="UserName" class="form-control form-control-lg auth-input" placeholder="admin" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" class="form-control form-control-lg auth-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 auth-button">Đăng nhập</button>
        </form>
    </div>
</div>

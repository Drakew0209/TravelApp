<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.SignUpPage"
             BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#111318}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="26,56,26,28" Spacing="18">
            <Border WidthRequest="42"
                    HeightRequest="42"
                    Stroke="{AppThemeBinding Light=#D6DCE8, Dark=#343B4A}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 21"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}" />
                </Border.GestureRecognizers>
                <Path Data="M19,6 L18,5 L12,11 L6,5 L5,6 L11,12 L5,18 L6,19 L12,13 L18,19 L19,18 L13,12 Z"
                      Fill="{AppThemeBinding Light=#333A4A, Dark=#F3F5FA}"
                      WidthRequest="16"
                      HeightRequest="16"
                      HorizontalOptions="Center"
                      VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Spacing="8" Margin="0,20,0,0">
                <Label Text="Sign Up"
                       Style="{StaticResource AuthTitleLabelStyle}" />
                <Label Text="Enjoy the free audio guided tours with ease and redeem the credits for paid tours."
                       Style="{StaticResource AuthSubtitleLabelStyle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource AuthInputBorderStyle}"
                    Margin="0,10,0,0">
                <Entry Placeholder="E-mail *"
                       Text="{Binding Email}"
                       AutomationProperties.Name="Email"
                       Style="{StaticResource AuthEntryStyle}" />
            </Border>

            <Border Style="{StaticResource AuthInputBorderStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Placeholder="Password *"
                           Text="{Binding Password}"
                           IsPassword="{Binding IsPasswordHidden}"
                           AutomationProperties.Name="Password"
                           Style="{StaticResource AuthEntryStyle}" />

                    <Button Grid.Column="1"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#8A8A93, Dark=#A8B0C4}"
                            FontSize="15"
                            Padding="0,0,4,0"
                            WidthRequest="56">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsPasswordHidden}"
                                         Value="True">
                                <Setter Property="Text" Value="Show" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsPasswordHidden}"
                                         Value="False">
                                <Setter Property="Text" Value="Hide" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <Border Style="{StaticResource AuthInputBorderStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Placeholder="Confirm password *"
                           Text="{Binding ConfirmPassword}"
                           IsPassword="{Binding IsConfirmPasswordHidden}"
                           AutomationProperties.Name="Confirm password"
                           Style="{StaticResource AuthEntryStyle}" />

                    <Button Grid.Column="1"
                            Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#8A8A93, Dark=#A8B0C4}"
                            FontSize="15"
                            Padding="0,0,4,0"
                            WidthRequest="56">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsConfirmPasswordHidden}"
                                         Value="True">
                                <Setter Property="Text" Value="Show" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsConfirmPasswordHidden}"
                                         Value="False">
                                <Setter Property="Text" Value="Hide" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <Label FontSize="16" TextColor="{AppThemeBinding Light=#2A2A31, Dark=#D7DEEC}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="By signing up, I agree with " />
                        <Span Text="Terms of Service" TextColor="#2A7DB3" TextDecorations="Underline" />
                        <Span Text=" and " />
                        <Span Text="Privacy statement" TextColor="#2A7DB3" TextDecorations="Underline" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Button Text="Sign Up"
                    Command="{Binding SignUpCommand}"
                    IsEnabled="{Binding IsSignUpEnabled}"
                    Style="{StaticResource PrimaryPillButtonStyle}"
                    Margin="0,4,0,0" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <Label Text="Have an account?"
                       FontSize="18"
                       TextColor="{AppThemeBinding Light=#1F1F24, Dark=#D7DEEC}" />
                <Label Text="Login"
                       FontSize="18"
                       TextColor="#D51963"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

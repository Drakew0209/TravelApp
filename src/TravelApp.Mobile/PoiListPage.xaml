<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.PoiListPage"
             Title="POI Live">

    <Grid RowDefinitions="Auto,*" Padding="12">
        <VerticalStackLayout Spacing="8">
            <Button Text="Reload now" Command="{Binding LoadPoisCommand}" />
            <Label Text="{Binding StatusText}" FontSize="12" TextColor="Gray" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Pois}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#DDDDDD" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8" Margin="0,0,0,8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding Location}" FontSize="13" />
                            <Label Text="{Binding Description}" FontSize="12" LineBreakMode="TailTruncation" MaxLines="2" />
                            <Label Text="{Binding DistanceMeters, StringFormat='Distance: {0:F0} m'}" FontSize="12" TextColor="#555555" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
